# Copy this file to /etc/pincer/pincer.env and adjust values.

# Ensure systemd can find asdf/mise shims if you installed Elixir via version manager.
PATH=/home/micelio/.asdf/shims:/home/micelio/.asdf/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin

# Runtime mode
MIX_ENV=prod

# Required tokens
TELEGRAM_BOT_TOKEN=put_real_token_here
OPENROUTER_API_KEY=put_real_key_here
OPENCODE_ZEN_API_KEY=put_real_key_here
GITHUB_PERSONAL_ACCESS_TOKEN=

# Optional hardening/runtime overrides
PINCER_NODE_COOKIE=change_me
